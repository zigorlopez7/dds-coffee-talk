{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.27/MicrosoftTeams.schema.json",
    "manifestVersion": "1.27",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "My App, Inc.",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termsofuse"
    },
    "icons": {
        "color": "logo.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "DDS Coffee Talk${{APP_NAME_SUFFIX}}",
        "full": "Full name for DDS Coffee Talk"
    },
    "description": {
        "short": "Short description of DDS Coffee Talk",
        "full": "Full description of DDS Coffee Talk"
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "bots": [],
    "composeExtensions": [],
    "staticTabs": [
        {
            "entityId": "home",
            "name": "Home",
            "contentUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "websiteUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "scopes": ["personal"]
        }
    ],
    "configurableTabs": [
        {
            "configurationUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "canUpdateConfiguration": true,
            "scopes": ["team", "groupChat"]
        }
    ],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "${{TAB_DOMAIN}}"
    ]
}